{
  "swagger": "2.0",
  "info": {
    "title": "Deploy com Cloud Run - golang",
    "description": "API para buscar o clima atual pelo CEP",
    "version": "1.0.0"
  },
  "host": "localhost:8080",
  "paths": {
    "/cep/{cep}": {
      "get": {        
        "summary": "Buscar Clima",
        "description": "Busca informações do clima atual da cidade.",
        "operationId": "GetTemperatura",
        "parameters": [
          {
            "name": "cep",
            "in": "path",
            "description": "CEP no formato XXXXXXXX (8 dígitos)",
            "required": true,
            "schema": {
              "type": "string",
              "example": "01153000"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "CEP encontrado com sucesso",
            "schema": {
              "type": "object",
              "properties": {
                "Temp_C": { "type": "number", "format": "float", "example": 22.5 },
                "Temp_F": { "type": "number", "format": "float", "example": 72.5 },
                "Temp_K": { "type": "number", "format": "float", "example": 295.65 }
              }
            }
          },
          "404": {
            "description": "can not find zipcode"
          },
          "422": {
            "description": "invalid zipcode"
          },
          "504": {
            "description": "Timeout de 5 segundos excedido - nenhuma API respondeu a tempo"
          }
        }
      }
    }
  }  
}
